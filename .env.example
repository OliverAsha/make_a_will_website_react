# ---- Booking system environment variables ----
# Copy this file to `.env.local` for local development (never commit .env.local).
# On Vercel, add each of these in your project's Settings → Environment Variables.

# --- Zoho OAuth ---
# Get these from https://api-console.zoho.com/ (create a "Server-based Applications" client).
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# One-time refresh token — generate this once using the steps in SETUP-BOOKING.md.
ZOHO_REFRESH_TOKEN=
# Use the domain for your Zoho region. UK/EU accounts use `.eu`; US accounts use `.com`.
ZOHO_ACCOUNTS_DOMAIN=accounts.zoho.eu
ZOHO_CALENDAR_DOMAIN=calendar.zoho.eu
# The UID of the calendar to write events into. Find it via the Zoho Calendar
# "List calendars" API call (instructions in SETUP-BOOKING.md).
ZOHO_CALENDAR_UID=

# --- Zoom Server-to-Server OAuth ---
# Get these from https://marketplace.zoom.us/ → Develop → Build App → Server-to-Server OAuth.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# The email address of the Zoom user who will host meetings.
ZOOM_USER_EMAIL=

# --- Booking settings ---
BOOKING_TIMEZONE=Europe/London
SLOT_MINUTES=30
WORK_START_HOUR=9
WORK_END_HOUR=17
# Minimum minutes between "now" and the earliest bookable slot.
LEAD_TIME_MINUTES=60
